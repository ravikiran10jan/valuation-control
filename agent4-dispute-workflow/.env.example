# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=valuation_control
POSTGRES_USER=vc_user
POSTGRES_PASSWORD=changeme

# ── Application ────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Dispute settings ──────────────────────────────────────
DESK_RESPONSE_DEADLINE_DAYS=2
ESCALATION_AUTO_DAYS=5
MAX_NEGOTIATION_ROUNDS=10

# ── Email (Microsoft Graph API for Outlook) ────────────────
EMAIL_PROVIDER=outlook
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=

# ── Email (SMTP fallback) ─────────────────────────────────
SMTP_HOST=smtp.bank.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Platform URL ──────────────────────────────────────────
VC_PLATFORM_BASE_URL=https://vc-platform.bank.com

# ── AWS S3 (document storage) ─────────────────────────────
S3_BUCKET=vc-platform-documents
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRY_SECONDS=604800
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Notification recipients ───────────────────────────────
VC_MANAGER_EMAIL=vc.manager@bank.com
VC_COMMITTEE_EMAIL=vc.committee@bank.com
